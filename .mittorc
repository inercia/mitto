metadata:
    description: A modern interface for AI coding agents with CLI, Web UI, and native macOS app. Communicates with agents via the Agent Client Protocol (ACP).
    url: https://github.com/inercia/mitto
processors:
    - enabled: true
      name: auggie-manage-rules
    - enabled: true
      name: claude-manage-memory
    - enabled: true
      name: memorize-preferences
    - enabled: true
      name: identify-user-data
prompts_dirs:
    - .mitto/prompts
